{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Mokimo Docs",
  "version": "0.3.0",
  "identifier": "uk.co.mokimo.docs",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "deep-link": {
      "desktop": {
        "schemes": ["mokimo-docs"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/TomGreenDesign/tg-docs-app/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIwMTdCOEVCODQyMzY4REYKUldUZmFDT0U2N2dYc1AralNlMGovSi9mbkZUSVR3anZjRXNSS2ZwUW5IYWhXYXhJMTI1ZUFIV0YK"
    }
  }
}
