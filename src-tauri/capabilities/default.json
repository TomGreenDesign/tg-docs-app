{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "deep-link:default",
    "updater:default"
  ],
  "remote": {
    "urls": ["https://dash.tomgreen.uk/*", "https://docs.tomgreen.uk/*"]
  }
}
